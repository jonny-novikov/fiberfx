{
  "title": "Codemoji Backend - APM Dashboard",
  "description": "Comprehensive APM dashboard for codemoji-backend on Fly.io",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "# Codemoji Backend APM\n\nBackend performance monitoring for the codemoji-backend service running on Fly.io.\n\n- **Environment**: production\n- **Platform**: Fly.io\n- **Agent**: sm-datadog-agent (FRA region)",
        "background_color": "blue",
        "font_size": "14",
        "text_align": "left",
        "vertical_align": "top",
        "show_tick": false,
        "tick_pos": "50%",
        "tick_edge": "left"
      }
    },
    {
      "definition": {
        "title": "Request Rate",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "bars",
            "q": "sum:trace.fastify.request.hits{service:codemoji-backend,env:production}.as_count()",
            "style": {
              "palette": "dog_classic"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "P95 Latency (ms)",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "line",
            "q": "p95:trace.fastify.request{service:codemoji-backend,env:production}",
            "style": {
              "palette": "warm"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "P99 Latency (ms)",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "line",
            "q": "p99:trace.fastify.request{service:codemoji-backend,env:production}",
            "style": {
              "palette": "orange"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Error Rate %",
        "type": "query_value",
        "precision": 2,
        "custom_unit": "%",
        "requests": [
          {
            "aggregator": "avg",
            "q": "sum:trace.fastify.request.errors{service:codemoji-backend,env:production}.as_count() / sum:trace.fastify.request.hits{service:codemoji-backend,env:production}.as_count() * 100"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Memory Usage (RSS)",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "area",
            "q": "avg:runtime.node.mem.rss{service:codemoji-backend,env:production}",
            "style": {
              "palette": "cool"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "CPU Usage",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "line",
            "q": "avg:runtime.node.cpu.usage{service:codemoji-backend,env:production}",
            "style": {
              "palette": "purple"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Event Loop Delay (avg)",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "line",
            "q": "avg:runtime.node.event_loop.delay.avg{service:codemoji-backend,env:production}",
            "style": {
              "palette": "orange"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Active Handles & Requests",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "line",
            "q": "avg:runtime.node.handles.active{service:codemoji-backend,env:production}",
            "style": {
              "palette": "green"
            }
          },
          {
            "display_type": "line",
            "q": "avg:runtime.node.requests.active{service:codemoji-backend,env:production}",
            "style": {
              "palette": "blue"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Host System Metrics",
        "type": "timeseries",
        "requests": [
          {
            "display_type": "area",
            "q": "avg:system.cpu.user{service:codemoji,platform:fly}",
            "style": {
              "palette": "dog_classic"
            }
          },
          {
            "display_type": "area",
            "q": "avg:system.cpu.system{service:codemoji,platform:fly}",
            "style": {
              "palette": "grey"
            }
          }
        ]
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "prefix": "env",
      "default": "production"
    },
    {
      "name": "service",
      "prefix": "service",
      "default": "codemoji-backend"
    }
  ],
  "notify_list": []
}
