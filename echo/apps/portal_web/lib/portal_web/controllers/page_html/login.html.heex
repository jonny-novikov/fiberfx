<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sign in · Functional Programming in Elixir · jonnify</title>
<meta name="description" content="Sign in to the learning portal with a username or email and password, or reset by email. Built on Portal.Auth, the project the course builds.">
<%!-- F6.8.1 (CSRF resolution (a)): protect_from_forgery stays ON; the page renders the
      request's CSRF token and login.js reads it for the x-csrf-token header on its POSTs. --%>
<meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
  onload="renderMathInElement(document.body,{delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\[',right:'\\]',display:true},{left:'\\(',right:'\\)',display:false}],throwOnError:false});"></script>
<link rel="stylesheet" href={~p"/assets/login.css"}>
</head>
<body data-level="basic">

<div class="topbar"><div class="topbar-inner">
  <a href="/elixir" class="brand">Learning Portal<span class="dot"></span><span class="sub">sign in</span></a>
  <nav class="nav-links"><a href="#how" class="nav-link">How it works</a><a href="/elixir" class="nav-link">The course</a><a href={PortalWeb.deep_link_base() <> "/elixir/course"} class="nav-link">F0 · Contents</a></nav>
  <a href="/" class="nav-link" style="border:1px solid var(--line);color:var(--cream-soft)">← Home Page</a>
</div></div>

<section class="hero" id="top"><div class="wrap"><div class="hero-grid">
  <div>
    <div class="hero-eyebrow"><span class="line"></span><span class="smallcaps">jonnify · learning portal · sign in</span></div>
    <h1 class="hero-title">Welcome <em>back</em><span style="color:var(--gold)">.</span></h1>
    <p class="hero-sub">Your progress, labs, and notes — behind one door. Sign in with the account name or email and the password; if the password has gone missing, the reset path is one step long.</p>
    <div class="auth-card" id="auth-card">
      <form id="signin-form" action="/auth/session" method="post" data-redirect="/elixir" novalidate>
        <div class="auth-field">
          <label class="auth-label" for="auth-ident">Username or email</label>
          <input class="auth-input" id="auth-ident" name="identifier" type="text" placeholder="ada — or ada@portal.dev" autocomplete="username" autocapitalize="none" spellcheck="false" required aria-describedby="ident-err">
          <p class="auth-ferr" id="ident-err" hidden>That does not look like a username or an email.</p>
        </div>
        <div class="auth-field">
          <label class="auth-label" for="auth-pass">Password</label>
          <div class="auth-pwrow">
            <input class="auth-input" id="auth-pass" name="password" type="password" autocomplete="current-password" required aria-describedby="pass-err caps-note">
            <button class="auth-peek" id="auth-peek" type="button" aria-pressed="false" aria-label="Show password" hidden>show</button>
          </div>
          <p class="auth-caps" id="caps-note" hidden>Caps Lock is on.</p>
          <p class="auth-ferr" id="pass-err" hidden>Enter the password — the field is empty.</p>
        </div>
        <button class="btn auth-send" id="signin-send" type="submit">Sign in</button>
        <div class="auth-row"><button class="auth-link" id="to-reset" type="button">Forgot password?</button><span class="hint" style="margin-top:0"></span></div>
      </form>
      <hr class="auth-divider" id="auth-divider">
      <form id="reset-form" action="/auth/reset" method="post" novalidate>
        <p class="auth-panel-label">Reset password</p>
        <p class="auth-reset-lede">Enter the email on the account. If it matches, a single-use reset link arrives within a minute — the portal answers the same way either way, so an address can not be fished for.</p>
        <div class="auth-field">
          <label class="auth-label" for="auth-remail">Account email</label>
          <input class="auth-input" id="auth-remail" name="email" type="email" placeholder="ada@portal.dev" autocomplete="email" autocapitalize="none" spellcheck="false" required aria-describedby="remail-err">
          <p class="auth-ferr" id="remail-err" hidden>That does not parse as an email address.</p>
        </div>
        <button class="btn auth-send" id="reset-send" type="submit">Email me a reset link</button>
        <div class="auth-row"><button class="auth-link" id="to-signin" type="button">← Back to sign in</button><span class="hint" style="margin-top:0">POST /auth/reset</span></div>
      </form>
      <div class="geo-readout" id="auth-readout" role="status" aria-live="polite">idle · enter a name or email, and the password</div>
    </div>
    <p class="auth-alt">No account yet — registration opens with the portal build. Soon.</p>
  </div>
  <div class="hero-visual">
    <div class="auth-flow">
      <svg class="flow-svg" id="flow-svg" viewBox="0 0 320 230" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The sign-in flow: credentials become a session, the session opens the course. A dashed branch below shows the reset link path for a lost password.">
        <path d="M50 130 C 96 110, 120 98, 160 80 C 200 62, 226 48, 270 30" fill="none" stroke="var(--line)" stroke-width="1.5"/>
        <path d="M50 130 C 60 165, 80 185, 110 196" fill="none" stroke="var(--line)" stroke-width="1.2" stroke-dasharray="3 5"/>
        <circle class="flow-halo" cx="50" cy="130" r="15" fill="var(--gold-bright)" fill-opacity="0.18"/>
        <circle class="st st0" cx="50" cy="130" r="7" fill="var(--gold)"/>
        <circle class="st st1" cx="160" cy="80" r="6" fill="var(--surface-3)" stroke="var(--line)" stroke-width="1.2"/>
        <circle class="st st2" cx="270" cy="30" r="6" fill="var(--surface-3)" stroke="var(--line)" stroke-width="1.2"/>
        <circle class="st stb" cx="110" cy="196" r="6" fill="var(--surface-3)" stroke="var(--line)" stroke-width="1.2"/>
        <text class="stl lb0" x="50" y="112" text-anchor="middle">sign_in/2</text>
        <text class="stl" x="160" y="106" text-anchor="middle">%Session{}</text>
        <text class="stl" x="270" y="56" text-anchor="middle">the course</text>
        <text class="stl lbb" x="110" y="216" text-anchor="middle">magic link</text>
        <text class="stl" x="50" y="148" text-anchor="middle" fill="#5a6489">this page</text>
      </svg>
      <p class="auth-flow-cap">Credentials become a session; a lost password takes the dashed road and comes back.</p>
    </div>
  </div>
</div></div></section>

<footer class="site-foot">
  <div class="wrap">
    <nav class="foot-nav" aria-label="Learning Portal — sign-in footer navigation">
      <div class="foot-brand">
        <a class="foot-logo" href="/elixir">Learning Portal<span class="dot"></span></a>
        <p class="foot-tag">One account for your progress, labs, and notes.</p>
      </div>
      <div class="foot-links">
        <p class="foot-h">The course</p>
        <a href="/elixir">Course home</a>
        <a href={PortalWeb.deep_link_base() <> "/elixir/course"}>Contents &amp; history</a>
        <a href={PortalWeb.deep_link_base() <> "/elixir/algebra/functions"}>Start &middot; F1.01</a>
      </div>
      <div class="foot-links">
        <p class="foot-h">This door</p>
        <a href="#top">Sign in</a>
        <a href="#top">Forgot password</a>
        <a href="/">&larr; Back to home page</a>
      </div>
    </nav>
    <div class="foot-bar">
      <p class="foot-cc">&copy; jonnify</p>
      <div class="stamp" id="stamp" role="button" tabindex="0" aria-expanded="false" aria-label="Learning Portal build stamp — activate to decode">
        <span class="lp">Learning Portal</span> build <span class="id" id="stampId">TSK0NjX1SacLQI</span>
        <dl class="panel">
          <dt>namespace</dt><dd id="st-ns">TSK</dd>
          <dt>snowflake</dt><dd id="st-snow">321294591590428674</dd>
          <dt>node</dt><dd id="st-node">7</dd>
          <dt>seq</dt><dd id="st-seq">2</dd>
          <dt>timestamp</dt><dd id="st-ts">2026-06-05 14:30:00 UTC</dd>
        </dl>
      </div>
    </div>
  </div>
</footer>

<script src={~p"/assets/login.js"}></script>
</body></html>
