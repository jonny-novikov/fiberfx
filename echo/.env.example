# Database config
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=codemojex
DATABASE_PASSWORD=codemojex_password
DATABASE_NAME=codemojex_dev
# Database Connection String
DATABASE_URL=postgres://codemojex:codemojex_password@localhost:5432/codemojex_dev

VALKEY_HOST=127.0.0.1
VALKEY_PORT=6390
VALKEY_PASSWORD=

SECRET_KEY_BASE=your_secret_key
CODEMOJI_BOT_TOKEN=your_bot_token

# Tigris bucket
AWS_ACCESS_KEY_ID=your_access_key
AWS_ENDPOINT_URL_S3=your_s3_endpoint_url
AWS_ENDPOINT_URL=your_endpoint_url
AWS_REGION=auto
BUCKET_NAME=your_bucket_name
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Tigris EDGE bucket — the hot-swap React game served at edge.codemoji.games
# (separate from the static welcome bucket; used by apps/codemojex/scripts/edge-deploy.sh).
# Setup: echo/docs/codemojex/edge-bucket-setup.md
TIGRIS_EDGE_BUCKET=codemojex-edge-prod
TIGRIS_EDGE_ENDPOINT_URL=your_tigris_s3_endpoint_url
TIGRIS_EDGE_ACCESS_KEY_ID=your_edge_access_key
TIGRIS_EDGE_SECRET_ACCESS_KEY=your_edge_secret_access_key
TIGRIS_EDGE_REGION=auto
GAME_EDGE_HOST=edge.codemoji.games
# Per-deploy fallback the app uses if the edge pointer is unreachable (set after the first deploy):
GAME_ASSET_URL=
