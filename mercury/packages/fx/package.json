{
  "name": "@echo/fx",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Rust-backed (wasm) compute primitives: BrandedId codec, Snowflake minter, routing hash. Fusion/work-stealing scheduler layered in TS over Node Cluster.",
  "main": "./ts/index.ts",
  "scripts": {
    "build": "wasm-pack build --release --target nodejs --out-dir pkg",
    "build:bundler": "wasm-pack build --release --target bundler --out-dir pkg-bundler",
    "test:rust": "cargo test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
