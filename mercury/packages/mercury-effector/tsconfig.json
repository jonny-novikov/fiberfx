{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["react"],
    "baseUrl": ".",
    // Resolve @mercury/ui from source for typechecking (apps do the same), so
    // newly-added exports are visible without a prebuild. No `rootDir`/declaration
    // here so the cross-package source files don't trip the rootDir check;
    // tsconfig.build.json re-adds them and resolves @mercury/ui via dist.
    "declaration": false,
    "paths": {
      "@mercury/ui": ["../mercury-ui/src/index.ts"],
      "@/*": ["../mercury-ui/src/*"]
    }
  },
  "include": ["src"]
}
