{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    // Declaration emit resolves @mercury/ui via its published dist (.d.ts), not
    // source — keeps emitted files under rootDir. Typecheck (tsconfig.json) uses
    // the source path-map; rebuild @mercury/ui before publishing this package.
    "paths": {}
  }
}
