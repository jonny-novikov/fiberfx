{
  "name": "@mercury/effector",
  "version": "2.4.0",
  "description": "Effector adapter for Mercury — theme store, toast model + Toaster, and a form/field factory. Components stay presentational.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/mercury-effector.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mercury/ui": "workspace:*",
    "effector": ">=23",
    "effector-react": ">=23",
    "react": ">=18"
  },
  "devDependencies": {
    "@mercury/ui": "workspace:*",
    "@types/react": "^19",
    "@vitejs/plugin-react": "^4.3.3",
    "effector": "^23.3.0",
    "effector-react": "^23.3.0",
    "react": "^19",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
