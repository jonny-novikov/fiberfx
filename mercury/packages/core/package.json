{
  "name": "@echo/core",
  "version": "0.1.0",
  "description": "Pure-TypeScript primitives for the echo surface: branded identity, error-as-value, TypeBox schemas, typed env.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.30",
    "neverthrow": "^8.2.0",
    "ts-pattern": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.0",
    "typescript": "catalog:"
  }
}
