{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "phoenix_live_view": ["../src/index.ts"],
      "phoenix_live_view/*": ["../src/*"]
    },
    "types": ["vitest/globals", "node"]
