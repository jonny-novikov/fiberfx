{
  "name": "@echo/phoenix",
  "version": "1.8.8",
  "description": "Typescript client for the Phoenix web framework",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "author": "Chris McCord <chris@chrismccord.com>, Jonnify <echo@jonnify.com>",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "test": "vitest",
    "build": "vite build",
    "build:client": "vite build --config vite.client.config.ts",
    "dev": "vite build --watch --config vite.client.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.1.0",
    "mock-socket": "^9.3.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vitest": "^4.0.16"
  }
}
