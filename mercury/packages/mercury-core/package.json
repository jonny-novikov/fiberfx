{
  "name": "@mercury/core",
  "version": "2.4.0",
  "description": "Mercury foundation — the UI-free layer: class utility, shared types, headless hooks, and locale-aware date formatters. No components, no styles. Consumed from source.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@internationalized/date": "^3.8.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "csstype": "^3.1.3",
    "react": "^19",
    "typescript": "^5.6.3"
  }
}
