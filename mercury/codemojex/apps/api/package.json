{
  "name": "codemojex-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@codemojex/types": "workspace:*",
    "@codemojex/db": "workspace:*",
    "@codemojex/dto": "workspace:*",
    "@echo/core": "workspace:*",
    "fastify": "^5.8.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.20.0",
    "drizzle-orm": "^0.45.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "@types/node": "^22.10.0"
  }
}
