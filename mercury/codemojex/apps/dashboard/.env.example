# admin.5-F2: same-origin — the Bearer token never crosses an origin in browser JS.
VITE_ADMIN_API_BASE=
# The operator Bearer credential (matches the admin service ADMIN_TOKEN).
VITE_ADMIN_TOKEN=
# Dev only: the admin service origin the Vite proxy forwards to (admin PORT 3000).
VITE_ADMIN_PROXY_TARGET=http://localhost:3000
