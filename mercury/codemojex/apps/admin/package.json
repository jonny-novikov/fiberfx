{
  "name": "@codemojex/admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "cluster": "tsx src/cluster.ts",
    "start:cluster": "node dist/cluster.js",
    "cluster:bun": "bun src/cluster.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "dev:bun": "bun --watch src/main.ts",
    "start:bun": "bun dist/main.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.2",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "dotenv": "^16.4.7",
    "iovalkey": "^0.3.1",
    "@echo/core": "workspace:*",
    "@sinclair/typebox": "^0.34.30",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@echo/cluster": "workspace:*",
    "@codemojex/db": "workspace:*",
    "@codemojex/domain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
