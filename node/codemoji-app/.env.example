# Codemoji Frontend Environment Variables

# Backend API URL
VITE_API_URL=https://codemoji-backend.ngrok.app/api/v2

# Enable debug logging (true/false)
VITE_DEBUG=true

# Use mock data instead of real API (true/false)
VITE_USE_MOCK=false

# Browser development mode - allows running outside Telegram (true/false)
VITE_BROWSER_MODE=false

# Maintenance mode - shows maintenance screen instead of app (true/false)
VITE_MAINTENANCE_MODE=false
