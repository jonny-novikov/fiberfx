{
  "name": "@codemoji/design",
  "version": "2.4.0",
  "type": "module",
  "private": true,
  "description": "Codemoji design system (tokens + theming + Storybook) + figma-local extraction toolkit",
  "bin": {
    "codemoji-design": "./bin/codemoji-design.mjs"
  },
  "exports": {
    "./theme.css": "./dist/theme.css",
    "./tokens": "./tokens/tokens.mjs"
  },
  "types": ".design-sync/entry.tsx",
  "scripts": {
    "doctor": "node bin/codemoji-design.mjs doctor",
    "extract": "node bin/codemoji-design.mjs extract",
    "sortout": "node bin/codemoji-design.mjs sortout",
    "theme": "node bin/codemoji-design.mjs theme",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "shoot": "node visual/shoot.mjs",
    "compare": "node visual/compare.mjs",
    "figma-export": "node visual/figma-export.mjs",
    "reexport-references": "node visual/reexport-references.mjs",
    "drift": "node visual/drift.mjs",
    "overlay": "node visual/overlay.mjs",
