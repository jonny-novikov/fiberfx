  "devDependencies": {
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "i18next": "^25.8.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^16.5.4",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
