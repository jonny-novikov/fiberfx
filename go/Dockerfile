# Build stage - builds both jonnify server and flyer CLI
FROM golang:1.25-alpine AS builder

# Install tar for creating distribution archives
RUN apk --no-cache add tar

WORKDIR /build

# ===== Build jonnify server =====
COPY go.mod go.sum* ./
RUN go mod download

COPY main.go .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o jonnify .

# ===== Runtime stage =====
FROM alpine:3.19

RUN apk --no-cache add ca-certificates

WORKDIR /app

# Copy jonnify server binary
COPY --from=builder /build/jonnify /app/jonnify

# Copy the lightweight landing-hub index.html served at "/"
# (the heavy three.js 3D map lives at /map via "COPY map/" below)
COPY html/index.html /app/html/index.html

# Copy SEO files (pre-generated by `make sitemap`) served at "/sitemap.xml" and "/robots.txt"
COPY html/sitemap.xml /app/html/sitemap.xml
COPY html/robots.txt /app/html/robots.txt
# Copy the llms.txt site map (llmstxt.org convention) served verbatim at "/llms.txt"
COPY html/llms.txt /app/html/llms.txt

# Copy the Elixir course (folder tree with subfolders) served under /elixir/*
COPY elixir/ /app/elixir/

# Copy the Redis Patterns course (folder tree → /redis-patterns/<chapter>/<module>) served under /redis-patterns/*
COPY html/redis-patterns/ /app/html/redis-patterns/

# Copy the EchoMQ course (folder tree → /echomq/<chapter>/<module>) served under /echomq/*
COPY html/echomq/ /app/html/echomq/

# Copy the BCS course (folder tree → /bcs/<chapter>/<module>) served under /bcs/*
COPY html/bcs/ /app/html/bcs/

# Copy the F# In Depth course (folder tree → /fsharp/<chapter>/<module>) served under /fsharp/*
COPY html/fsharp/ /app/html/fsharp/

# Copy The Art of BCS course (folder tree → /art/<chapter>/<dive>) served under /art/*
COPY html/art/ /app/html/art/

# Copy EchoMesh, In Depth course (folder tree → /mesh/<chapter>/<dive>) served under /mesh/*
COPY html/mesh/ /app/html/mesh/

# Copy the Agile Agent Workflow course (folder tree) served under /agile-agent-workflow/*
COPY html/agile-agent-workflow/ /app/html/agile-agent-workflow/

# Copy styled HTML error pages (<status>.html) served by the central error
# handler — e.g. 404.html for unmatched routes, 500.html for panics.
COPY html/error/ /app/html/error/

EXPOSE 8080

CMD ["/app/jonnify"]
