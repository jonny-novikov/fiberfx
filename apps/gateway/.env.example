# =============================================================================
# FiberFx Gateway - Environment Configuration Template
# =============================================================================
#
# Copy this file to .env.local and fill in values for local development
# For Fly.io deployment, set these as secrets: fly secrets set KEY=VALUE
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Connection
# -----------------------------------------------------------------------------
# PostgreSQL connection URL (required)
# For Fly.io internal: postgres://user:pass@db-app.internal:5432/database
# For local development: postgres://user:pass@localhost:5432/database
DATABASE_URL="postgres://username:password@host:5432/database"

# Database driver: "postgres" (default) or "sqlite"
DRIVER="postgres"

# SQLite path (only used when DRIVER=sqlite)
SQLITE_PATH="./data/app.db"

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# JWT signing secret (use a strong random string in production)
JWT_SECRET="your-secret-key-change-in-production"

# Master password for admin login (shared secret)
MASTER_PASSWORD="your-admin-password"

# JWT cookie settings
COOKIE_SECURE="false"  # Set to "true" in production
COOKIE_DOMAIN=""       # Leave empty for localhost

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Server port
PORT="8080"

# Server hostname (for CORS, cookie domain)
HOST_NAME="localhost:8080"

# Debug mode (enables request logging)
DEBUG="true"

# -----------------------------------------------------------------------------
# s3explorer Configuration
# -----------------------------------------------------------------------------
# Port where s3explorer listens
S3_EXPLORER_PORT="3008"

# Working directory for s3explorer
S3_EXPLORER_WORK_DIR="./s3explorer"

# Command to run s3explorer
S3_EXPLORER_CMD=

# Web assets directory (Svelte login page)
WEB_DIR="./web/dist"
